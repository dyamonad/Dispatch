<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml
    Root layout for MainActivity. Contains:
      - A toolbar at the top with a server IP input field and connect button.
      - A DesktopWindowView that fills the remaining space, drawing
        proportional representations of the desktop terminal windows.
      - A status bar at the bottom showing connection / recording state.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <!-- ── Connection bar ── -->
    <LinearLayout
        android:id="@+id/layoutConnection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/surface_dark"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/editServerIp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/hint_server_ip"
            android:inputType="textUri"
            android:text="@string/default_server_ip"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:backgroundTint="@color/accent"
            android:imeOptions="actionDone"
            android:singleLine="true" />

        <Button
            android:id="@+id/btnConnect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/btn_connect"
            android:backgroundTint="@color/accent" />

    </LinearLayout>

    <!-- ── Desktop window canvas ── -->
    <com.dispatch.app.DesktopWindowView
        android:id="@+id/desktopWindowView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/layoutConnection"
        app:layout_constraintBottom_toTopOf="@id/layoutStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Status bar ── -->
    <LinearLayout
        android:id="@+id/layoutStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="@color/surface_dark"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/status_disconnected"
            android:textColor="@color/status_disconnected"
            android:textSize="13sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvHints"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/hints"
            android:textColor="@color/text_hint"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginTop="2dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
